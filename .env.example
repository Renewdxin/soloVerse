ANTHROPIC_API_KEY=
# GitHub PAT：读代码 + 写评论/issue（开 thread）；不给写代码权限
GITHUB_TOKEN=

# 飞书（Lark）自建应用
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Discord bot
DISCORD_BOT_TOKEN=
# 管家主人的飞书 open_id：群上岗审批 / 控制命令走他的私聊。**启用飞书时必填**。
# 不知道自己的 open_id？先启动，给 bot 发条私聊，日志里会打印你的 open_id。
OPERATOR_FEISHU_OPEN_ID=
# 群发言权种子（逗号分隔 chat_id）。**可选**：群会从消息流自助发现（默认只读），
# operator 私聊回「开启」提权即可，无需在这里列。这里列的是「首次种子」，之后 DB 是运行时真相。
# 可读写：bot 在群里能确认/催办/发台账。ALLOWED_GROUP_REFS 是它的兼容别名。
ALLOWED_GROUP_REFS=
GROUPS_READ_WRITE=
# 只读：存上下文、绝不在群里发言（个人事项之后走私聊 digest）。
GROUPS_READ_ONLY=

# Supabase 或 Neon 的 Postgres 连接串（标准 PG 连接串，不走 MCP）；留空则用内存 Store（仅测试/冒烟）
DATABASE_URL=
TZ=Asia/Shanghai
QUIET_HOURS=23-8
# 隐形：一天最多催一次
MAX_REMINDERS_PER_DAY=1
TICK_MS=60000
# 个人 digest 默认发送本地时间(每人可在 Person.digestPref 覆盖)
DIGEST_TIME=10:30

# LLM / pi：core 不直接读取这些，app/config 解析后注入 adapter
LLM_PROVIDER=anthropic
LLM_MODEL_ID=claude-sonnet-4-6
LLM_CACHE_RETENTION=short
# provider=anthropic 默认读上面的 ANTHROPIC_API_KEY；其它 provider 用对应 key
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# LLM_API_KEY 优先于按 provider 推断的 key（任意 provider 都可显式覆盖）
# LLM_API_KEY=
# openai-compatible 端点（provider=openai-compatible 时 BASE_URL + API_KEY 必填）
# LLM_BASE_URL=
# 各 openai-compatible 实现的兼容开关；不设则用 SDK 默认
# LLM_COMPAT_SUPPORTS_STORE=
# LLM_COMPAT_SUPPORTS_DEVELOPER_ROLE=
# LLM_COMPAT_SUPPORTS_REASONING_EFFORT=
# LLM_COMPAT_SUPPORTS_USAGE_IN_STREAMING=
# LLM_COMPAT_SUPPORTS_STRICT_MODE=
# LLM_COMPAT_MAX_TOKENS_FIELD=        # max_completion_tokens | max_tokens

# ToolRunner（只读 review）：默认继承上面的 LLM 配置，下面几项可单独覆盖
TOOL_RUNNER_CWD=
TOOL_RUNNER_MODEL_PROVIDER=anthropic
TOOL_RUNNER_MODEL_ID=claude-sonnet-4-6
# TOOL_RUNNER_API_KEY=
# TOOL_RUNNER_BASE_URL=

# link verifier 抓取（SafeLinkFetcher）；仅 ENABLE_WEBFETCH=1 时生效，留空用代码默认值
# LINK_FETCH_ALLOWED_HOSTS=github.com,raw.githubusercontent.com,docs.github.com
# LINK_FETCH_TIMEOUT_MS=5000
# LINK_FETCH_MAX_BYTES=200000
# LINK_FETCH_MAX_REDIRECTS=3
# LINK_FETCH_ALLOWED_CONTENT_TYPES=text/html,text/plain,application/json,text/markdown

# 数据保留与 profile 有界参数
RAW_EVIDENCE_RETENTION_DAYS=30
PROFILE_HINTS_CAP=5
PENDING_PROFILE_PROPOSALS_CAP=3

# 高副作用/未稳定能力显式开关
ENABLE_REVIEW=0
ENABLE_WEBFETCH=0
ENABLE_PROFILE_REFLECTION=0
